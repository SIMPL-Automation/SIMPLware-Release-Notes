{
  "version": "2.0.0",
  "inputs": [
    {
      "id": "releaseVersion",
      "type": "promptString",
      "description": "Release version to export (e.g. 3.0.3)"
    }
  ],
  "tasks": [
    {
      "label": "Serve",
      "type": "shell",
      "command": "docsify serve ./docs",
      "options": {
        "env": {
          "CHOKIDAR_USEPOLLING": "1"
        }
      },
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "problemMatcher": []
    },
    {
      "label": "Export release notes PDF",
      "type": "shell",
      "command": "node ./scripts/export-release-pdf.mjs ${input:releaseVersion}",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "CHOKIDAR_USEPOLLING": "1"
        }
      },
      "group": "none",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}
